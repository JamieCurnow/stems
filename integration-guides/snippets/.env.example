## Local dev secrets — gitignored. Mirror in `wrangler secret put X --env <env>`
## for deployed envs. Read from `event.context.cloudflare.env`, never process.env.

## Better Auth
# 32 random bytes hex: `npx better-auth secret` or `openssl rand -hex 32`
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

## Stripe — test mode for dev
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
# Optional, only if you keep referrals
STRIPE_REFERRAL_COUPON_ID=
# The single secret printed by `stripe listen` covers both webhook URLs in dev.
# In deployed envs each webhook has its own secret.
STRIPE_WEBHOOK_SECRET=
STRIPE_REFERRAL_WEBHOOK_SECRET=

## Email (Resend) — required to send transactional & marketing emails
RESEND_API_KEY=
# Default From — must use a verified Resend domain
MAIL_FROM={{APP_NAME}} <{{MAIL_FROM_LOCAL}}@{{APP_DOMAIN}}>
# Public origin used to build absolute links inside emails
PUBLIC_BASE_URL=http://localhost:3000
# Optional: signing secret for Resend webhook (bounce/complaint suppression)
RESEND_WEBHOOK_SECRET=

## Admin gate — shared secret for /api/admin/*, /api/cron/*
# 32 random bytes hex: `openssl rand -hex 32`
ADMIN_API_SECRET=
# Optional comma-separated extra admin emails (extends compiled-in defaults)
ADMIN_EMAILS=

## Analytics — GTM + GA4 (all optional; integration is a no-op when unset)
# GTM-XXXXXXX — drives all client-side analytics (GA4 configured inside GTM)
NUXT_PUBLIC_GTM_ID=
# G-XXXXXXXXXX — used by server-side Measurement Protocol calls
NUXT_PUBLIC_GA4_MEASUREMENT_ID=
# Created in GA4 Admin → Data Streams → your stream → Measurement Protocol API secrets
GA4_API_SECRET=
